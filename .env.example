# Application
APP_NAME=教育服务系统 API
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true

# MySQL database: education_service
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=education_service
DB_CHARSET=utf8mb4
# DATABASE_URL=mysql+pymysql://root:change-me@127.0.0.1:3306/education_service?charset=utf8mb4
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# JWT and password security
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_HOURS=24
BCRYPT_COST=12

# Dify
DIFY_API_BASE_URL=http://localhost:5001/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx
# Dify HTTP nodes send: Authorization: Bearer <DIFY_SERVICE_TOKEN>
DIFY_SERVICE_TOKEN=service-xxxxxxxxxxxx

# LLM
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=qwen-plus
LLM_TIMEOUT=120
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# Customer profile rules and uploads
PRODUCT_RULES_PATH=产品线匹配规则.md
PRODUCT_CATALOG_PATH=全产品线目录.md
UPLOAD_DIR=uploads/profiles
MAX_UPLOAD_SIZE=10485760
