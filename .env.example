# 教育服务系统 - 环境变量示例
# 复制此文件为 .env 并修改配置

APP_NAME=education-service-api
APP_ENV=development
APP_DEBUG=true

# MySQL 数据库连接
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/education_service?charset=utf8mb4

# JWT 密钥（生产环境请更换为随机字符串）
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_HOURS=24

# Dify 配置
DIFY_API_BASE_URL=http://localhost:8080/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx
DIFY_SERVICE_TOKEN=service-xxxxxxxxxxxx

# LLM 直连配置（替代 Dify 的 AI 能力）
# OpenAI:       LLM_API_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
# DeepSeek:     LLM_API_URL=https://api.deepseek.com/v1 LLM_MODEL=deepseek-chat
# Ollama (本地): LLM_API_URL=http://localhost:11434/v1  LLM_MODEL=llama3
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60

# 智能报告内容生成（纯 Python，不使用 Dify）
# REPORT_AI_MODE=llm 时必须配置 REPORT_LLM_API_KEY；示例值不可用于真实调用。
REPORT_AI_MODE=llm
REPORT_LLM_PROVIDER=deepseek
REPORT_LLM_BASE_URL=https://api.deepseek.com
REPORT_LLM_MODEL=deepseek-v4-pro
REPORT_LLM_API_KEY=sk-your-report-key
REPORT_LLM_TIMEOUT=180
REPORT_LLM_MAX_RETRIES=2

# 智能报告助手开关与意图解析
# 助手调用同一个 ReportLLMClient，因此真实凭据仍从 REPORT_LLM_* 读取。
REPORT_ASSISTANT_ENABLED=true
REPORT_ASSISTANT_LLM_ENABLED=true
REPORT_ASSISTANT_PROVIDER=deepseek
REPORT_ASSISTANT_MODEL=deepseek-v4-pro
REPORT_ASSISTANT_BASE_URL=https://api.deepseek.com
REPORT_ASSISTANT_TIMEOUT_SECONDS=180
REPORT_ASSISTANT_MAX_RETRIES=2

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
