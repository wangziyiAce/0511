# ==================== 应用配置 ====================
SECRET_KEY=your-secret-key-here
DEBUG=true

# ==================== 数据库 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=education_service

# ==================== JWT 认证 ====================
JWT_SECRET_KEY=jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ==================== Dify AI 平台 ====================
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-xxxxxxxxxxxxx
# Dify HTTP 节点调用 FastAPI 白名单接口时使用的服务令牌（独立于用户 JWT）
DIFY_SERVICE_TOKEN=dify-service-token-change-me
